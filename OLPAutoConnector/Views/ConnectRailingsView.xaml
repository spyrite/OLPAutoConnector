<mah:MetroWindow x:Class="OLP.AutoConnector.Views.ConnectRailingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OLP.AutoConnector.Views"
        xmlns:viewmodels="clr-namespace:OLP.AutoConnector.ViewModels" 
        xmlns:resources="clr-namespace:OLP.AutoConnector.Resources"
        xmlns:customs="clr-namespace:OLP.AutoConnector.Customs"
        d:DataContext="{d:DesignInstance Type=viewmodels:ConnectRailingsVM}"
                 
        mc:Ignorable="d"
        Title="{Binding TitleWithVersion}" 
                 Height="auto" 
                 Width="440"
                 SizeToContent="Height"
                 WindowStartupLocation="CenterScreen"
                 ResizeMode="NoResize">

    <mah:MetroWindow.Resources>
        <ResourceDictionary>
            <customs:VisibilityConverter x:Key="myVisibilityConverter"/>
            <Image x:Key="RadioButton1" Source="/AutoConnector;component/Resources/Images/ConnectRailingsView_RadioButton1.png" Margin="2,2,2,2"/>
            <Image x:Key="RadioButton2" Source="/AutoConnector;component/Resources/Images/ConnectRailingsView_RadioButton2.png" Margin="2,2,2,2"/>
            <Image x:Key="RadioButton3" Source="/AutoConnector;component/Resources/Images/ConnectRailingsView_RadioButton3.png" Margin="2,2,2,2"/>
            <Image x:Key="RadioButton4" Source="/AutoConnector;component/Resources/Images/ConnectRailingsView_RadioButton4.png" Margin="2,2,2,2"/>
            <FrameworkElement x:Key="ProxyElement" DataContext="{Binding}"/>
            
            
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Colors.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Accents/Blue.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Accents/BaseLight.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.AnimatedTabControl.xaml" />
                <ResourceDictionary Source="pack://application:,,,/AutoConnector;component/resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            
        </ResourceDictionary>
        
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Справка" 
                        VerticalAlignment="Center"
                        Command="{Binding HelpOpen}"
                        Margin="10,0,10,0"/>
            </StackPanel>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="230"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="240"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        

        <GroupBox Grid.Row="0"
                  Header="Выберите тип соединения"
                  Margin="0,5,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="130"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <RadioButton x:Name="RadioButton1"
                             Grid.Column="0" Grid.Row="0"
                             GroupName="Types"
                             Style="{StaticResource RadioButtonStyleDefault}"
                             IsChecked="{Binding ConnectionType1Selected}"
                             IsEnabled="{Binding AllowConnectionType1}"
                             Content="{StaticResource RadioButton1}">
                    </RadioButton>
                    <RadioButton x:Name="RadioButton2" 
                             GroupName="Types"
                             Style="{StaticResource RadioButtonStyleDefault}"
                             IsChecked="{Binding ConnectionType2Selected}"
                             IsEnabled="{Binding AllowConnectionType2}"
                             Content="{StaticResource RadioButton2}"/>
                    <RadioButton x:Name="RadioButton3"
                             GroupName="Types"
                             Style="{StaticResource RadioButtonStyleDefault}"
                             IsChecked="{Binding ConnectionType3Selected}"
                             IsEnabled="{Binding AllowConnectionType3}"
                             Content="{StaticResource RadioButton3}"/>
                    <RadioButton x:Name="RadioButton4" 
                             GroupName="Types"
                             Style="{StaticResource RadioButtonStyleDefault}"
                             IsChecked="{Binding ConnectionType4Selected}"
                             IsEnabled="{Binding AllowConnectionType4}"
                             Content="{StaticResource RadioButton4}"/>
                </StackPanel>
                <StackPanel Grid.Row="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding UpperRailingInfo}"
                               Style="{StaticResource TextBlockStyleDefault}"
                               Foreground="DarkGray"/>
                    <TextBlock Text="{Binding LowerRailingInfo}"
                               Style="{StaticResource TextBlockStyleDefault}"
                               Foreground="DarkGray"/>
                </StackPanel>

            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1"
                    Visibility="{Binding AllowSelectHandrail, Converter={StaticResource myVisibilityConverter}}"
                    Background="#41B1E1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Stretch"
                    Margin="0,5,0,0"
                    Height="30">
            <TextBlock Text="ВЫБЕРИТЕ СОЕДИНЯЕМЫЕ ПОРУЧНИ"
                       Foreground="White"
                       Margin="5,0,10,0"
                       VerticalAlignment="Center"/>
            <RadioButton Content="ВЕРХНИЕ"
                         Foreground="White"
                         Margin="5,5,5,5"
                         FontWeight="DemiBold"
                         IsChecked="{Binding UpperHandrailSelected}"/>
            <RadioButton Content="НИЖНИЕ"
                         Foreground="White"
                         Margin="5,5,5,5"
                         FontWeight="DemiBold"
                         IsChecked="{Binding LowerHandrailSelected}"/>

        </StackPanel>

        <StackPanel Grid.Row="2"
                    Visibility="{Binding AllowConnectHorizontalBalusters, Converter={StaticResource myVisibilityConverter}}"
                    Background="#41B1E1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Stretch"
                    Margin="0,5,0,5"
                    Height="30">
            <CheckBox Content="СОЕДИНЯТЬ ГОРИЗОНТАЛЬНЫЕ СВЯЗИ"
                      Foreground="White"
                      Margin="5,0,0,0"
                      VerticalAlignment="Center"
                      IsChecked="{Binding ConnectHorizontalBalusters}"/>
        </StackPanel>

        <GroupBox Grid.Row="3"
                  Header="Введите расстояния">
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding UpperRailingConnectionXDesctription}"
                           Style="{StaticResource TextBlockAllowUpperRailingConnectionX}"/>
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{Binding UpperRailingConnectionDZDesctription}"
                           Style="{StaticResource TextBlockAllowUpperRailingConnectionDZ}"/>
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{Binding LowerRailingConnectionXDesctription}"
                           Style="{StaticResource TextBlockAllowLowerRailingConnectionDZ}"/>

                <StackPanel Grid.Row="0" Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text=" X = "
                               Style="{StaticResource TextBlockAllowUpperRailingConnectionX}"/>
                    <TextBox x:Name="TextBox1"
                             Style="{StaticResource TextBoxAllowUpperRailingConnectionX}"
                             PreviewTextInput="TextBox1_PreviewTextInput"
                             Width="40"/>
                    <TextBox x:Name="TextBox11"
                             Style="{StaticResource TextBoxAllowUpperRailingConnectionX}"
                             PreviewTextInput="TextBox1_PreviewTextInput"
                             Text="{Binding HorizontalBalustersConnectionX1}"
                             Visibility="{Binding ConnectHorizontalBalusters, Converter={StaticResource myVisibilityConverter}}"
                             Width="40"/>
                    <TextBlock Text="мм"
                               Style="{StaticResource TextBlockAllowUpperRailingConnectionX}"/>
                </StackPanel>


                <StackPanel Grid.Row="1" Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Z1 = "
                               Style="{StaticResource TextBlockAllowUpperRailingConnectionDZ}"/>
                    <TextBox x:Name="TextBox2"
                             Style="{StaticResource TextBoxAllowUpperRailingConnectionDZ}"
                             PreviewTextInput="TextBox234_PreviewTextInput"
                             Width="40"/>
                    <TextBox x:Name="TextBox22"
                             Style="{StaticResource TextBoxAllowUpperRailingConnectionDZ}"
                             PreviewTextInput="TextBox234_PreviewTextInput"
                             Visibility="{Binding ConnectHorizontalBalusters, Converter={StaticResource myVisibilityConverter}}"
                             Text="{Binding UpperHorizontalBalustersConnectionDZ1}"
                             Width="40"/>
                    <TextBlock Text="мм"
                               Style="{StaticResource TextBlockAllowUpperRailingConnectionDZ}"/>
                </StackPanel>


                <StackPanel Grid.Row="2" Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="Z2 = "
                               Style="{StaticResource TextBlockAllowLowerRailingConnectionDZ}"/>
                    <TextBox x:Name="TextBox3"
                             Style="{StaticResource TextBoxAllowLowerRailingConnectionDZ}"
                             PreviewTextInput="TextBox234_PreviewTextInput"
                             Width="40"/>
                    <TextBox x:Name="TextBox33"
                             Style="{StaticResource TextBoxAllowLowerRailingConnectionDZ}"
                             PreviewTextInput="TextBox234_PreviewTextInput"
                             Visibility="{Binding ConnectHorizontalBalusters, Converter={StaticResource myVisibilityConverter}}"
                             Text="{Binding UpperHorizontalBalustersConnectionDZ1}"
                             Width="40"/>
                    <TextBlock Text="мм"
                               Style="{StaticResource TextBlockAllowLowerRailingConnectionDZ}"/>
                </StackPanel>

            </Grid>
        </GroupBox>

        <Grid Grid.Row="4"
              Margin="10,10,2,10">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Row="0"
                      Grid.Column="0"
                      Style="{StaticResource CheckBoxStyleDefault}"
                      Content="Выбрать ещё"
                      IsChecked="{Binding SelectAnymore}"/>

            <CheckBox Grid.Row="1"
                      Grid.Column="0"
                      Style="{StaticResource CheckBoxStyleDefault}"
                      Content="C вызовом данного окна"
                      IsChecked="{Binding SelectAnymoreWithDialog}"
                      IsEnabled="{Binding AllowSelectAnymoreWithDialog}"/>

            <StackPanel Grid.RowSpan="2" 
                        Grid.Column="1"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                <Button x:Name="OKButton"
                            Content="OK"
                            Style="{StaticResource ButtonStyleDefault}"
                            IsDefault = "true"
                            Click="OKButton_Click"/>

                <Button x:Name="CancelButton"
                        Content="Отмена"
                        Style="{StaticResource ButtonStyleDefault}"
                        IsCancel="True"/>
            </StackPanel>

        </Grid>

        

    </Grid>
</mah:MetroWindow>
