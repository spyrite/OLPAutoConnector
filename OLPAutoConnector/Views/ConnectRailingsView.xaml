<mah:MetroWindow x:Class="OLP.AutoConnector.Views.ConnectRailingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OLP.AutoConnector.Views"
        xmlns:viewmodels="clr-namespace:OLP.AutoConnector.ViewModels" 
        xmlns:resources="clr-namespace:OLP.AutoConnector.Resources"
        d:DataContext="{d:DesignInstance Type=viewmodels:ConnectRailingsVM}"
                 
        mc:Ignorable="d"
        Title="{Binding TitleWithVersion}" 
        Width="440"
        Height="auto"
        SizeToContent="Height"
        ShowInTaskbar="True" WindowStartupLocation="CenterScreen"
        ShowMaxRestoreButton="False"
        ShowMinButton="False"
        ResizeMode="NoResize">

    <mah:MetroWindow.Resources>
        <ResourceDictionary>
            <Image x:Key="RadioButton1" Source="/AutoConnector;component/Resources/Images/ConnectRailingsView_RadioButton1.png" Margin="2,2,2,2"/>
            <Image x:Key="RadioButton2" Source="/AutoConnector;component/Resources/Images/ConnectRailingsView_RadioButton2.png" Margin="2,2,2,2"/>
            <Image x:Key="RadioButton3" Source="/AutoConnector;component/Resources/Images/ConnectRailingsView_RadioButton3.png" Margin="2,2,2,2"/>
            <Image x:Key="RadioButton4" Source="/AutoConnector;component/Resources/Images/ConnectRailingsView_RadioButton4.png" Margin="2,2,2,2"/>
            <FrameworkElement x:Key="ProxyElement" DataContext="{Binding}"/>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Fonts.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Colors.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Accents/Blue.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Accents/BaseLight.xaml" />
                <ResourceDictionary Source="pack://application:,,,/MahApps.Metro;component/Styles/Controls.AnimatedTabControl.xaml" />
                <ResourceDictionary Source="pack://application:,,,/AutoConnector;component/resources/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
        
    </mah:MetroWindow.Resources>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Справка" 
                        VerticalAlignment="Center"
                        Command="{Binding HelpOpen}"
                        Margin="10,0,10,0"/>
            </StackPanel>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="230"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <GroupBox Grid.Row="0"
                  Header="Выберите тип соединения"
                  Margin="0,5,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="130"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <RadioButton x:Name="RadioButton1"
                             Grid.Column="0" Grid.Row="0"
                             GroupName="Types"
                             Style="{StaticResource RadioButtonStyleDefault}"
                             IsChecked="{Binding ConnectionType1Selected}"
                             IsEnabled="{Binding AllowConnectionType1}"
                             Content="{StaticResource RadioButton1}">
                    </RadioButton>
                    <RadioButton x:Name="RadioButton2" 
                             GroupName="Types"
                             Style="{StaticResource RadioButtonStyleDefault}"
                             IsChecked="{Binding ConnectionType2Selected}"
                             IsEnabled="{Binding AllowConnectionType2}"
                             Content="{StaticResource RadioButton2}"/>
                    <RadioButton x:Name="RadioButton3"
                             GroupName="Types"
                             Style="{StaticResource RadioButtonStyleDefault}"
                             IsChecked="{Binding ConnectionType3Selected}"
                             IsEnabled="{Binding AllowConnectionType3}"
                             Content="{StaticResource RadioButton3}"/>
                    <RadioButton x:Name="RadioButton4" 
                             GroupName="Types"
                             Style="{StaticResource RadioButtonStyleDefault}"
                             IsChecked="{Binding ConnectionType4Selected}"
                             IsEnabled="{Binding AllowConnectionType4}"
                             Content="{StaticResource RadioButton4}"/>
                </StackPanel>
                <StackPanel Grid.Row="1"
                            Orientation="Vertical"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding UpperRailingInfo, Mode=OneTime}"
                               Style="{StaticResource TextBlockStyleDefault}"
                               Foreground="DarkGray"/>
                    <TextBlock Text="{Binding LowerRailingInfo, Mode=OneTime}"
                               Style="{StaticResource TextBlockStyleDefault}"
                               Foreground="DarkGray"/>
                </StackPanel>

            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1"
                  Header="Сопоставьте поручни и введите расстояния">
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="45"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="{Binding LowerHadrailColumnWidth}"/>
                    <ColumnDefinition Width="30"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{Binding UpperRailingH}"
                           Style="{StaticResource TextBlockStyleDefault}"/>
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{Binding LowerRailingH}"
                           Style="{StaticResource TextBlockStyleDefault}"/>
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{Binding UpperRailingConnectionXDesctription}"
                           Style="{StaticResource TextBlockAllowUpperRailingConnectionX}"/>
                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="{Binding UpperRailingConnectionDZDesctription}"
                           Style="{StaticResource TextBlockAllowUpperRailingConnectionDZ}"/>
                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="{Binding LowerRailingConnectionXDesctription}"
                           Style="{StaticResource TextBlockAllowLowerRailingConnectionDZ}"/>

                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text=" H1 ="
                           Style="{StaticResource TextBlockStyleDefault}"/>

                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text=" H2 ="
                           Style="{StaticResource TextBlockStyleDefault}"/>

                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text=" X ="
                           Style="{StaticResource TextBlockAllowUpperRailingConnectionX}"/>

                <TextBlock Grid.Row="3" Grid.Column="1"
                           Text="Z1 ="
                           Style="{StaticResource TextBlockAllowUpperRailingConnectionDZ}"/>

                <TextBlock Grid.Row="4" Grid.Column="1"
                           Text="Z2 ="
                           Style="{StaticResource TextBlockAllowLowerRailingConnectionDZ}"/>

                <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="{Binding HandrailMappingFirst.UpperRailingHandrailData.DisplayHeight}"
                               HorizontalAlignment="Center"
                               Style="{StaticResource TextBlockStyleDefault}"/>
                <ComboBox Grid.Row="1" Grid.Column="2"
                              ItemsSource="{Binding AvailableLowerRailingHandrails }"
                              Style="{StaticResource ComboBoxStyleDefault}"
                              DisplayMemberPath="DisplayHeight"
                              SelectedItem="{Binding HandrailMappingFirst.LowerRailingHandrailData}"/>

                <TextBox Grid.Row="2" Grid.Column="2"
                             x:Name="TextBox11"
                             Style="{StaticResource TextBoxStyleDefault}"
                             IsEnabled="{Binding AllowUpperRailingConnectionX, Mode=OneWay}"
                             Text="{Binding HandrailMappingFirst.UpperRailingConnectionX}"
                             PreviewTextInput="TextBox1_PreviewTextInput"/>

                <TextBox Grid.Row="3" Grid.Column="2"
                             x:Name="TextBox12"
                             Style="{StaticResource TextBoxStyleDefault}"
                             IsEnabled="{Binding AllowUpperRailingConnectionDZ, Mode=OneWay}"
                             Text="{Binding HandrailMappingFirst.UpperRailingConnectionDZ}"
                             PreviewTextInput="TextBox23_PreviewTextInput"/>

                <TextBox Grid.Row="4" Grid.Column="2"
                             x:Name="TextBox13"
                             Style="{StaticResource TextBoxStyleDefault}"
                             IsEnabled="{Binding AllowLowerRailingConnectionDZ, Mode=OneWay}"
                             Text="{Binding HandrailMappingFirst.LowerRailingConnectionDZ}"
                             PreviewTextInput="TextBox23_PreviewTextInput"/>

                <TextBlock Grid.Row="0" Grid.Column="3"
                               Text="{Binding HandrailMappingLast.UpperRailingHandrailData.DisplayHeight}"
                               HorizontalAlignment="Center"
                               Style="{StaticResource TextBlockStyleDefault}"/>
                <ComboBox Grid.Row="1" Grid.Column="3"
                              ItemsSource="{Binding AvailableLowerRailingHandrails }"
                              Style="{StaticResource ComboBoxStyleDefault}"
                              DisplayMemberPath="DisplayHeight"
                              SelectedItem="{Binding HandrailMappingLast.LowerRailingHandrailData}"/>

                <TextBox Grid.Row="2" Grid.Column="3"
                             x:Name="TextBox21"
                             Style="{StaticResource TextBoxStyleDefault}"
                             IsEnabled="{Binding AllowUpperRailingConnectionX, Mode=OneWay}"
                             Text="{Binding HandrailMappingLast.UpperRailingConnectionX}"
                             PreviewTextInput="TextBox1_PreviewTextInput"/>

                <TextBox Grid.Row="3" Grid.Column="3"
                             x:Name="TextBox22"
                             Style="{StaticResource TextBoxStyleDefault}"
                             IsEnabled="{Binding AllowUpperRailingConnectionDZ, Mode=OneWay}"
                             Text="{Binding HandrailMappingLast.UpperRailingConnectionDZ}"
                             PreviewTextInput="TextBox23_PreviewTextInput"/>

                <TextBox Grid.Row="4" Grid.Column="3"
                             x:Name="TextBox23"
                             Style="{StaticResource TextBoxStyleDefault}"
                             IsEnabled="{Binding AllowLowerRailingConnectionDZ, Mode=OneWay}"
                             Text="{Binding HandrailMappingLast.LowerRailingConnectionDZ}"
                             PreviewTextInput="TextBox23_PreviewTextInput"/>

                <TextBlock Grid.Row="0" Grid.Column="4"
                           Text="мм"
                           Style="{StaticResource TextBlockStyleDefault}"/>

                <TextBlock Grid.Row="1" Grid.Column="4"
                           Text="мм"
                           Style="{StaticResource TextBlockStyleDefault}"/>

                <TextBlock Grid.Row="2" Grid.Column="4"
                           Text="мм"
                           Style="{StaticResource TextBlockAllowUpperRailingConnectionX}"/>

                <TextBlock Grid.Row="3" Grid.Column="4"
                           Text="мм"
                           Style="{StaticResource TextBlockAllowUpperRailingConnectionDZ}"/>

                <TextBlock Grid.Row="4" Grid.Column="4"
                           Text="мм"
                           Style="{StaticResource TextBlockAllowLowerRailingConnectionDZ}"/>

            </Grid>
        </GroupBox>

        <Grid Grid.Row="2"
              Margin="10,10,2,10">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Row="0"
                      Grid.Column="0"
                      Style="{StaticResource CheckBoxStyleDefault}"
                      Content="Выбрать ещё"
                      IsChecked="{Binding SelectAnymore}"/>

            <CheckBox Grid.Row="1"
                      Grid.Column="0"
                      Style="{StaticResource CheckBoxStyleDefault}"
                      Content="C вызовом данного окна"
                      IsChecked="{Binding SelectAnymoreWithDialog}"
                      IsEnabled="{Binding AllowSelectAnymoreWithDialog}"/>

            <StackPanel Grid.RowSpan="2" 
                        Grid.Column="1"
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Margin="0,0,10,0">
                <Button x:Name="OKButton"
                            Content="OK"
                            Style="{StaticResource ButtonStyleDefault}"
                            IsDefault = "true"
                            Click="OKButton_Click"/>

                <Button x:Name="CancelButton"
                        Content="Отмена"
                        Style="{StaticResource ButtonStyleDefault}"
                        IsCancel="True"/>
            </StackPanel>

        </Grid>

        

    </Grid>
</mah:MetroWindow>
